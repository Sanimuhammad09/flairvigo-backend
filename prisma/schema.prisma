datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// ---------------------------------------------------------
// User & Auth
// ---------------------------------------------------------
enum Role {
  USER
  ADMIN
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               Role               @default(USER)
  isEmailVerified    Boolean            @default(false)
  avatar             String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  addresses          Address[]
  orders             Order[]
  reviews            Review[]
  wishlist           Wishlist?
  cart               Cart?
  fitProfile         FitProfile?
  embroideryDesigns  EmbroideryDesign[]
  waitlists          Waitlist[]
  notifications      Notification[]
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault Boolean  @default(false)
  firstName String
  lastName  String
  address1  String
  address2  String?
  city      String
  state     String
  country   String
  zipCode   String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// Product Catalog
// ---------------------------------------------------------
model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  fitRules    FitRule[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Collection {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  description      String
  fabricDetails    String?
  careInstructions String?
  basePrice        Float
  isFeatured       Boolean          @default(false)
  isActive         Boolean          @default(true)
  categoryId       String
  category         Category         @relation(fields: [categoryId], references: [id])
  collectionId     String?
  collection       Collection?      @relation(fields: [collectionId], references: [id])
  
  variants         ProductVariant[]
  images           ProductImage[]
  videos           ProductVideo[]
  reviews          Review[]
  waitlists        Waitlist[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ProductVariant {
  id           String         @id @default(uuid())
  productId    String
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku          String         @unique
  barcode      String?        @unique
  color        String
  colorHex     String?
  size         String
  priceOffset  Float          @default(0)
  inventory    Int            @default(0)
  
  cartItems    CartItem[]
  orderItems   OrderItem[]
  wishlistItems WishlistItem[]
  stockHistory StockHistory[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([productId, color, size])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  order     Int      @default(0)
  isMain    Boolean  @default(false)
}

model ProductVideo {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  thumbnail String?
  order     Int      @default(0)
}

// ---------------------------------------------------------
// Reviews & Ratings
// ---------------------------------------------------------
model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int      // 1-5
  title     String?
  content   String
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// Cart & Wishlist
// ---------------------------------------------------------
model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id                 String          @id @default(uuid())
  cartId             String
  cart               Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId          String
  variant            ProductVariant  @relation(fields: [variantId], references: [id])
  quantity           Int             @default(1)
  hasEmbroidery      Boolean         @default(false)
  embroideryDesignId String?
  embroideryDesign   EmbroideryDesign? @relation(fields: [embroideryDesignId], references: [id])
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model Wishlist {
  id        String         @id @default(uuid())
  userId    String         @unique
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id        String         @id @default(uuid())
  wishlistId String
  wishlist  Wishlist       @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  createdAt DateTime       @default(now())
}

// ---------------------------------------------------------
// Orders & Payments
// ---------------------------------------------------------
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id            String               @id @default(uuid())
  orderNumber   String               @unique
  userId        String
  user          User                 @relation(fields: [userId], references: [id])
  status        OrderStatus          @default(PENDING)
  totalAmount   Float
  subtotal      Float
  taxAmount     Float
  shippingCost  Float
  discountAmount Float               @default(0)
  couponCode    String?
  
  shippingAddress Json
  billingAddress  Json
  
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payment       Payment?
  invoice       Invoice?
  
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
}

model OrderItem {
  id                 String           @id @default(uuid())
  orderId            String
  order              Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId          String
  variant            ProductVariant   @relation(fields: [variantId], references: [id])
  quantity           Int
  unitPrice          Float
  hasEmbroidery      Boolean          @default(false)
  embroideryDesignId String?
  embroideryDesign   EmbroideryDesign? @relation(fields: [embroideryDesignId], references: [id])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
}

model Payment {
  id            String   @id @default(uuid())
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String   // 'stripe', 'paystack', 'flutterwave'
  transactionId String   @unique
  amount        Float
  currency      String   @default("USD")
  status        String   // 'succeeded', 'pending', 'failed'
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoice {
  id        String   @id @default(uuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pdfUrl    String
  createdAt DateTime @default(now())
}

model Coupon {
  id            String   @id @default(uuid())
  code          String   @unique
  type          String   // 'percentage', 'fixed', 'free_shipping'
  value         Float
  minOrderValue Float?
  maxDiscount   Float?
  startDate     DateTime?
  endDate       DateTime?
  usageLimit    Int?
  usageCount    Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------
// Inventory & Waitlist
// ---------------------------------------------------------
model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockHistory {
  id           String         @id @default(uuid())
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity     Int            // Positive for addition, negative for reduction
  reason       String         // 'purchase', 'restock', 'return', 'damage'
  referenceId  String?        // Order ID or purchase order ID
  createdAt    DateTime       @default(now())
}

model Waitlist {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  email     String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  isNotified Boolean @default(false)
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------
// Unique Features: Fit Finder & Embroidery
// ---------------------------------------------------------
model FitProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender        String
  heightCm      Float
  weightKg      Float
  bodyShape     String
  preferredFit  String   // 'slim', 'regular', 'relaxed'
  brandSizeRef  String?
  ageRange      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FitRule {
  id            String   @id @default(uuid())
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  ruleLogic     Json     // Admin configurable rules
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmbroideryDesign {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  placement   String   // 'front', 'sleeve', 'back'
  fontName    String
  threadColor String
  text        String
  price       Float
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIPreview {
  id          String   @id @default(uuid())
  previewUrl  String
  config      Json     // Details of selected options
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------
// Notifications & Comms
// ---------------------------------------------------------
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   // 'order', 'promo', 'system'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Newsletter {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Report {
  id        String   @id @default(uuid())
  name      String
  type      String   // 'sales', 'inventory', 'customers'
  url       String
  createdBy String   // Admin ID
  createdAt DateTime @default(now())
}
